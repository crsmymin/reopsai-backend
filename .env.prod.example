# ===========================================
# Backend Production Environment (EC2 + RDS)
# ===========================================

# Runtime
FLASK_ENV=production
ENVIRONMENT=production
DEBUG=false
PORT=5001
PYTHONUNBUFFERED=1
SQLALCHEMY_ECHO=false

# Security
JWT_SECRET_KEY=replace-with-long-random-secret

# API Keys
OPENAI_API_KEY=replace-with-openai-key
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=

# URLs / CORS
FRONTEND_URL=https://reopsai.com
BACKEND_URL=https://reopsai.com/api
ALLOWED_ORIGINS=https://reopsai.com

# Database (AWS RDS)
# Example:
# DATABASE_URL=postgresql+psycopg2://app_user:app_password@my-rds.cluster-xxxx.ap-northeast-2.rds.amazonaws.com:5432/smart_research
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<rds-endpoint>:5432/<db_name>
