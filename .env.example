# ===========================================
# Backend Production Environment (EC2 + RDS)
# ===========================================

# Runtime
FLASK_ENV=production
ENVIRONMENT=production
DEBUG=false
PORT=5001
PYTHONUNBUFFERED=1
SQLALCHEMY_ECHO=false

# Security
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=None

# API Keys
OPENAI_API_KEY=
GOOGLE_API_KEYS=
GOOGLE_CLIENT_ID=

# URLs / CORS
FRONTEND_URL=https://reopsai.com
BACKEND_URL=https://reopsai.com/api
ALLOWED_ORIGINS=https://reopsai.com,https://stage.reopsai.com,https://main.d18rr0wdie06s6.amplifyapp.com

# Database (AWS RDS)
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<rds-endpoint>:5432/<db_name>
